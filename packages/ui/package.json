{
  "name": "@april/ui",
  "version": "0.1.0",
  "description": "April design system — Mantine-based UI, patterns, and showcase components",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "sideEffects": ["**/*.css", "./dist/**/*.css"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "license": "UNLICENSED",
  "publishConfig": {
    "access": "restricted"
  },
  "peerDependencies": {
    "@emotion/react": "^11.0.0",
    "@mantine/core": "^7.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-hook-form": "^7.0.0",
    "zod": "^3.22.0"
  },
  "peerDependenciesMeta": {
    "react-hook-form": { "optional": true },
    "zod": { "optional": true }
  },
  "dependencies": {
    "@april/tokens": "workspace:*",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@xyflow/react": "^12.3.0",
    "lucide-react": "0.522.0"
  },
  "devDependencies": {
    "@mantine/core": "^7.13.4",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.5.4"
  }
}
