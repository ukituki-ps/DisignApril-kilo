{
  "name": "@ukituki-ps/april-ui",
  "version": "0.1.4",
  "description": "April design system — Mantine-based UI, patterns, and showcase components",
  "repository": {
    "type": "git",
    "url": "https://github.com/ukituki-ps/DisignApril.git",
    "directory": "packages/ui"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css",
    "./dist/**/*.css"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "license": "UNLICENSED",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "peerDependencies": {
    "@emotion/react": "^11.0.0",
    "@mantine/core": "^7.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-hook-form": "^7.0.0",
    "zod": "^3.22.0"
  },
  "peerDependenciesMeta": {
    "react-hook-form": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "dependencies": {
    "@apidevtools/json-schema-ref-parser": "^15.3.5",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@rjsf/core": "^6.5.1",
    "@rjsf/utils": "^6.5.1",
    "@rjsf/validator-ajv8": "^6.5.1",
    "@ukituki-ps/april-tokens": "workspace:*",
    "@xyflow/react": "^12.3.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "json-edit-react": "^1.29.0",
    "lucide-react": "0.522.0"
  },
  "devDependencies": {
    "@mantine/core": "^7.13.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "jsdom": "^27.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.5.4",
    "vitest": "^3.2.4"
  }
}
